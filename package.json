{
  "name": "late-eastern-han-dynasty",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "author": "CtxPilot",
  "scripts": {
    "dev": "pnpm --parallel --filter @leh/server --filter @leh/client dev",
    "dev:server": "pnpm --filter @leh/server dev",
    "dev:client": "pnpm --filter @leh/client dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "validate-data": "pnpm --filter @leh/server validate-data",
    "verify-scenario-events": "pnpm --filter @leh/server verify-scenario-events",
    "verify-campaign": "pnpm --filter @leh/server verify-campaign",
    "verify-save-entities": "pnpm --filter @leh/server verify-save-entities",
    "verify-save-campaign": "pnpm --filter @leh/server verify-save-campaign",
    "verify-save-battle": "pnpm --filter @leh/shared build && pnpm --filter @leh/server verify-save-battle",
    "verify-save-diplomacy": "pnpm --filter @leh/shared build && pnpm --filter @leh/server verify-save-diplomacy",
    "verify-save-intel": "pnpm --filter @leh/shared build && pnpm --filter @leh/server verify-save-intel",
    "verify-save-plot": "pnpm --filter @leh/shared build && pnpm --filter @leh/server verify-save-plot",
    "verify-save-game-state": "pnpm --filter @leh/shared build && pnpm --filter @leh/server verify-save-game-state",
    "verify-save-migration": "pnpm --filter @leh/shared build && pnpm --filter @leh/server verify-save-migration",
    "verify-battle-rng": "pnpm --filter @leh/shared build && pnpm --filter @leh/server verify-battle-rng",
    "verify-duel-rng": "pnpm --filter @leh/shared build && pnpm --filter @leh/server verify-duel-rng",
    "test": "pnpm --filter @leh/shared test",
    "spdx": "node scripts/add-spdx-headers.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
